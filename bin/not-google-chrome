#!/usr/bin/env bash
# Headless DOM dump (default) or persistent CDP session (--cdp) against the
# user's logged-in Chromium. Strategy and decisions (why Chromium, why the live
# user-data-dir, etc.): ../BROWSER.md.
#
# Usage:
#   not-google-chrome [-t SECONDS] [--pdf PATH] URL [extra-flag ...]
#       Render URL's DOM to stdout (default), or write a PDF (--pdf).
#   not-google-chrome --cdp [-t SECONDS] [--host HOST] -- <client command ...>
#       Provide a CDP browser to the client: export CDP_WS_URL (a page-target
#       websocket) and CDP_PORT into the client's environment, run the client,
#       and on every exit path tear the browser down. The browser comes from one
#       of two sources, decided at run time:
#         - Overseer (local browser broker on 127.0.0.1:11402, env BI_OVERSEER_PORT
#           to override): if it answers /health, lease a browser from it, hand the
#           client the relay websocket as CDP_WS_URL (CDP_PORT empty, no local debug
#           port), and release the lease on exit. The overseer owns the browser and
#           its serialization, so no flock and no Chromium launch here. --host HOST
#           labels the lease for the overseer's per-site gate (default localhost;
#           site skills pass their own, e.g. --host instagram.com).
#         - Standalone (overseer absent): launch a persistent Chromium owned by the
#           wrapper -- one browser at a time (flock), a deadman timeout, and a
#           teardown that finds the browser by its --remote-debugging-port and
#           signals that PID, since a persistent browser reparents to the user
#           service manager once the wrapper returns and a PID captured at launch
#           would be stale.
#       Client scripts hold no browser PID; they connect to CDP_WS_URL and drive
#       the page.
#
# Output:  rendered DOM on stdout (default), or PDF written to PATH (--pdf). In
#          --cdp mode the client owns stdout. Redirect dump-dom stdout to a file:
#          dumps are commonly several MB and flood caller context if returned
#          directly. Default timeout 15s (dump-dom), 90s (--cdp); -t overrides.
#          Pass extra Chrome-compatible flags after the URL (dump-dom only).
# Exit 64: bad usage. Exit 75: timed out waiting for /tmp/chromium.lock.
#          Exit 76: the profile Chromium would open has startup set to "Continue
#          where you left off", which restores tabs and hangs a one-shot render.
#          Exit 77: URL on the abuse list (override with --yes-i-am-not-stupid).
#          Exit 78: unsupported OS, missing dependency, CDP endpoint never came
#          up, or [browser] config missing from config.ini.
#
# Logging: failure modes (render timeout, empty result, lock-wait timeout, CDP
#          endpoint failure) are written to syslog via `logger -t not-google-chrome`
#          so a later session has evidence of flaky behavior rather than a guess.
#          Inspect with `journalctl -t not-google-chrome` (systemd) or the syslog.
#
# macOS prerequisite: brew install util-linux coreutils (flock, gtimeout).
# Linux has both natively.
#
# Conventions:
#   - --headless=new, not legacy --headless.
#   - Do not set --virtual-time-budget for general use; a few skills
#     (instagram, facebook) pass it explicitly because their JS-rendered
#     endpoints need a budget.
#   - UA override is required, read from [browser] user_agent in
#     $HOME/.claude/skills/config.ini (--cdp also reads accept_lang). It defeats
#     sites that block on the literal string HeadlessChrome, and keeps the fetch
#     fingerprint matching the user's logged-in browser session.
#
# When to call this wrapper vs WebFetch:
#   Prefer WebFetch when the site allows it (converts HTML to plain text
#   before loading into context, far smaller than a raw DOM dump). Fall
#   back to this wrapper only when bot detection blocks WebFetch.

set -euo pipefail

# Abuse list. URLs containing any of these substrings are refused unless
# --yes-i-am-not-stupid is passed. The wrapper exists for sites that block
# automated access (Akamai, Cloudflare, login walls). For these patterns,
# WebFetch or curl is cheaper, faster, and does not lock the user's user-data-dir.
# Edit this list when a new common-abuse case shows up; a tighter pattern
# beats a looser one (prefer "www.google." over "google" so we do not catch
# a randomly-named google-something on a legitimate target site).
ABUSE_PATTERNS=(
  "google.com"
  "www.google."
  "wikipedia.org"
  "github.com"
  "raw.githubusercontent.com"
  "news.ycombinator.com"
  "stackoverflow.com"
  "arxiv.org"
  "archive.org"
)

timeout=""
mode_args=(--dump-dom)
override=0
cdp=0
pdf=0
lock_wait=30
CDP_FIXED_PORT=9223   # fixed (not 0) so teardown can match the browser by its
                      # unique cmdline; flock guarantees one CDP browser at a time.
_cdp_port=""          # set once the browser is launched; read by cdp_teardown.
cdp_host=localhost    # --cdp --host: gate label handed to the overseer lease;
                      # a generic default for ad-hoc fetches. Site skills pass
                      # their own (e.g. --host instagram.com).

# Local browser broker. When the overseer is listening here, --cdp delegates the
# browser to it instead of launching its own Chromium (see run_cdp). Honor the
# env override so a test overseer on another port is reachable; the listener is
# Bearer-free locally, so no auth header is sent.
OVERSEER_BASE="http://127.0.0.1:${BI_OVERSEER_PORT:-11402}"
_lease_id=""          # set once a lease is granted; read by lease_teardown.

# Read one value from config.ini. Empty output if section/key absent.
config_get() {  # $1=section $2=key
  awk -v sect="$1" -v key="$2" '
    /^[[:space:]]*\[/ { gsub(/[][[:space:]]/, ""); cur=$0; next }
    cur==sect && $0 ~ ("^[[:space:]]*" key "[[:space:]]*=") {
      sub(/^[^=]*=[[:space:]]*/, ""); sub(/[[:space:]]+$/, ""); print; exit
    }
  ' "$config"
}

# Record a failure mode to syslog so a later session has evidence instead of a
# guess (e.g. whether a site's headless fetch is genuinely flaky, which otherwise
# leaves no trace). Fail-open: if logger is absent the wrapper still works.
log_event() {  # $1=syslog level (warning/err/info)  $2=message
  command -v logger >/dev/null 2>&1 && logger -t not-google-chrome -p "user.$1" -- "$2" 2>/dev/null || true
}

# Classify a process holding a Chromium-related lock. Prints the binary and
# cmdline, and when the cmdline carries --headless adds an explicit note that
# the holder is a leaked agent process, not a desktop browser the user opened —
# so a downstream report does not falsely tell the user to close a window they
# never opened. Distinguishing chromium (this wrapper) from chrome (the user's
# GUI Chrome, separate user-data-dir) belongs to the reader of the binary path
# this prints.
classify_holder() {  # $1=pid; prints to stderr
  local pid="$1" cmd="" bin=""
  if [[ -r "/proc/$pid/cmdline" ]]; then
    cmd="$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null)"
    bin="$(readlink "/proc/$pid/exe" 2>/dev/null || true)"
  elif [[ "$(uname)" == Darwin ]]; then
    cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  fi
  if [[ -z "$cmd" ]]; then
    echo "  pid $pid: process gone or unreadable" >&2
    return
  fi
  echo "  pid $pid: exe=${bin:-?}  cmdline=${cmd}" >&2
  if [[ "$cmd" == *"--headless"* ]]; then
    echo "    NOTE: this holder ran with --headless. It is a leaked agent process, NOT a desktop browser the user opened. Do not tell the user to close a window." >&2
  fi
}

# Diagnose a lock we could not acquire within lock_wait: name the holder so a
# stuck session is fast and legible instead of an indefinite hang.
lock_diag() {
  local holder pid
  holder="$(fuser /tmp/chromium.lock 2>/dev/null | tr -s ' ' || true)"
  echo "not-google-chrome: timed out after ${lock_wait}s waiting for /tmp/chromium.lock (holder PID(s):${holder:- unknown})." >&2
  for pid in $holder; do
    [[ "$pid" =~ ^[0-9]+$ ]] && classify_holder "$pid"
  done
}

# In one-shot render mode (--dump-dom / --pdf), refuse to launch if the profile
# Chromium will open has its startup set to "Continue where you left off"
# (restore_on_startup:1). That reopens the previous session's tabs on every
# launch; the one-shot render then waits for all of them to finish loading and
# hangs indefinitely, emitting nothing. CDP is immune (it reads its own target on
# a timer, never waiting for the browser to settle). This fails OPEN on any parse
# uncertainty, so a Local State / Preferences format change cannot wedge the
# wrapper; it only bails on a positively-read restore_on_startup of 1.
dumpdom_startup_guard() {
  local ls="$user_data_dir/Local State" prof="" pref ros=""
  # Which profile will a no-profile-directory launch open? last_active_profiles[0],
  # else last_used, else Default. Each read ends with "|| true": under the
  # wrapper's `set -o pipefail`, a grep that finds no match (e.g. an empty
  # last_active_profiles []) would otherwise abort the whole wrapper.
  if [[ -f "$ls" ]]; then
    prof="$(grep -oE '"last_active_profiles":\[[^]]*\]' "$ls" 2>/dev/null | sed 's/.*\[//' | grep -oE '"[^"]*"' | head -1 | tr -d '"' || true)"
    [[ -n "$prof" ]] || prof="$(grep -oE '"last_used":"[^"]*"' "$ls" 2>/dev/null | head -1 | sed 's/.*"last_used":"//; s/"$//' || true)"
  fi
  [[ -n "$prof" ]] || prof="Default"
  pref="$user_data_dir/$prof/Preferences"
  [[ -f "$pref" ]] || return 0
  ros="$(grep -oE '"restore_on_startup":[0-9]+' "$pref" 2>/dev/null | head -1 | grep -oE '[0-9]+$' || true)"
  [[ "$ros" == "1" ]] || return 0
  cat >&2 <<EOF
not-google-chrome: refusing to render. Chromium profile "$prof" has its startup
set to "Continue where you left off" (restore_on_startup=1). That reopens the
previous session's tabs on every launch; --dump-dom/--pdf then wait for those
tabs to finish loading and hang indefinitely with no output, so this is refused
rather than left to hang (see ../BROWSER.md).

Fix: in that profile's Chromium, Settings > On startup > "Open the New Tab page",
then retry. CDP mode (--cdp) is immune and unaffected by this setting.
EOF
  exit 76
}

# Teardown of a delegated lease (overseer broker mode). The overseer owns the
# browser, so the only thing to release is the lease: POST /browser/release with
# the lease id on every exit path. Fail-open (the overseer reaps abandoned leases
# on its own deadman), so a release that does not reach the overseer never wedges
# the wrapper. No Bearer: the listener is Bearer-free locally.
lease_teardown() {
  trap - EXIT INT TERM
  local id="${_lease_id:-}"
  if [[ -n "$id" ]]; then
    curl -s --max-time 5 -o /dev/null \
      -X POST -H 'Content-Type: application/json' \
      -d "{\"leaseId\":\"$id\"}" \
      "$OVERSEER_BASE/browser/release" 2>/dev/null || true
  fi
}

# Teardown of the CDP browser. A persistent browser reparents to the user
# service manager once the wrapper returns, so a PID captured at launch goes
# stale. Find the live browser by the one stable attribute only its main process
# carries, the --remote-debugging-port string, and signal that PID: SIGTERM to
# let Chromium flush, then SIGKILL if it does not exit. This assumes the child
# renderer, GPU and zygote processes then exit on their own once the main process
# is gone; that has held in use so far but is unverified, the SIGKILL path
# especially, since a hard-killed main runs no shutdown to bring them down (see
# chromium-process-model.md F7). (A cgroup never intercepts signals, so a per-pid
# signal reaches the browser in any scope.)
cdp_teardown() {
  trap - EXIT INT TERM
  local port="${_cdp_port:-}"
  if [[ -n "$port" ]] && pgrep -f -- "remote-debugging-port=$port" >/dev/null 2>&1; then
    pkill -TERM -f -- "remote-debugging-port=$port" 2>/dev/null || true
    local i
    for i in 1 2 3 4 5 6; do
      pgrep -f -- "remote-debugging-port=$port" >/dev/null 2>&1 || break
      sleep 0.5
    done
    if pgrep -f -- "remote-debugging-port=$port" >/dev/null 2>&1; then
      pkill -KILL -f -- "remote-debugging-port=$port" 2>/dev/null || true
    fi
  fi
  # A SIGKILL escalation can leave Chromium's Singleton{Lock,Cookie,Socket}
  # symlinks pointing at a now-dead PID, which blocks the next launch. Remove any
  # that reference a non-existent process. Linux-only: the liveness check is /proc.
  if [[ "$(uname)" == Linux && -n "${user_data_dir:-}" ]]; then
    local s tgt spid
    for s in SingletonLock SingletonCookie SingletonSocket; do
      tgt="$(readlink "$user_data_dir/$s" 2>/dev/null || true)"
      [[ -z "$tgt" ]] && continue
      spid="${tgt##*-}"
      if [[ "$spid" =~ ^[0-9]+$ && ! -e "/proc/$spid" ]]; then
        rm -f "$user_data_dir/$s" 2>/dev/null || true
      fi
    done
  fi
  exec 9>&- 2>/dev/null || true   # release the flock
}

# CDP mode: acquire the lock, launch the browser, hand the client a page-target
# websocket, run it under a deadman, reap the browser on every exit path.
run_cdp() {
  local port="$CDP_FIXED_PORT" ws_url="" i rc=0

  # Local browser broker. If the overseer answers /health here, delegate the
  # browser to it (lease -> hand the client the relay websocket as CDP_WS_URL ->
  # release) instead of launching our own Chromium. The overseer owns the browser
  # and its own serialization, so this path takes no /tmp/chromium.lock flock, does
  # no foreign-profile check, launches nothing, and polls no /json endpoint. When
  # the overseer is absent (connection refused / timeout / non-200) the probe falls
  # through to the standalone path below, byte-for-byte as before.
  if [[ "$(curl -s --max-time 1 -o /dev/null -w '%{http_code}' "$OVERSEER_BASE/health" 2>/dev/null || true)" == 200 ]]; then
    local lease_json relay
    lease_json="$(curl -s --max-time 10 \
      -X POST -H 'Content-Type: application/json' \
      -d "{\"host\":\"$cdp_host\"}" \
      "$OVERSEER_BASE/browser/lease" 2>/dev/null || true)"
    # Same JSON-extraction style as the /json target read below: a stdlib python3
    # one-liner reading the field, empty on any parse failure.
    _lease_id="$(printf '%s' "$lease_json" | python3 -c '
import json, sys
try:
    print(json.load(sys.stdin).get("leaseId", "") or "")
except Exception:
    pass
' 2>/dev/null || true)"
    relay="$(printf '%s' "$lease_json" | python3 -c '
import json, sys
try:
    print(json.load(sys.stdin).get("cdpRelay", "") or "")
except Exception:
    pass
' 2>/dev/null || true)"
    if [[ -z "$_lease_id" || -z "$relay" ]]; then
      echo "not-google-chrome: overseer on $OVERSEER_BASE is up but did not grant a browser lease (response: ${lease_json:-<empty>})" >&2
      log_event err "cdp lease failed against overseer $OVERSEER_BASE: ${client_cmd[*]}"
      lease_teardown   # release the lease if one was partially granted
      exit 78
    fi
    trap 'lease_teardown; exit 130' INT TERM
    trap lease_teardown EXIT

    # No local debug port in delegate mode: the relay carries CDP, CDP_PORT empty.
    export CDP_WS_URL="$relay" CDP_PORT=""
    "$timeout_cmd" "$timeout" "${client_cmd[@]}" || rc=$?
    if [[ $rc -eq 124 || $rc -eq 137 ]]; then
      log_event warning "cdp client timed out after ${timeout}s (exit $rc): ${client_cmd[*]}"
    fi
    exit "$rc"
  fi

  exec 9>/tmp/chromium.lock
  if ! "$flock_cmd" -w "$lock_wait" 9; then
    lock_diag
    log_event warning "cdp lock-wait timeout after ${lock_wait}s: ${client_cmd[*]}"
    exit 75
  fi

  # With the flock held, no sibling not-google-chrome instance is running, so any
  # live Chromium still on this profile is foreign: a browser the user opened, or
  # another launcher that bypasses this lock. Our headless instance cannot attach
  # to an occupied profile; it lands on an error page and every in-page fetch()
  # then fails with a misleading "Failed to fetch", which callers read as a site
  # block or rate limit. Refuse with the real cause instead. The check sits after
  # the flock on purpose: ahead of it, a transient sibling dump (which the flock
  # serialises) shows a live SingletonLock and would be misread as a foreign
  # holder and refused. SingletonLock is Chromium's own contention marker; its
  # target is "<host>-<pid>", trusted only if that pid is alive (stale locks are
  # swept at teardown).
  if [[ "$(uname)" == Linux ]]; then
    local _stgt _spid
    _stgt="$(readlink "$user_data_dir/SingletonLock" 2>/dev/null || true)"
    _spid="${_stgt##*-}"
    if [[ "$_spid" =~ ^[0-9]+$ && -e "/proc/$_spid" ]]; then
      echo "not-google-chrome: a Chromium (pid $_spid) holds the SingletonLock on $user_data_dir, so the headless CDP instance cannot read the logged-in session. This is a profile lock, not a network or site-side error (not a block or rate limit)." >&2
      classify_holder "$_spid"
      log_event warning "cdp refused: chromium pid $_spid holds $user_data_dir: ${client_cmd[*]}"
      exit 75
    fi
  fi

  # Fixed port + an explicit about:blank so a page target exists immediately.
  # 9>&- so the browser does not inherit (and pin) the lock fd.
  "$binary" "${user_data_dir_args[@]}" \
    --headless=new \
    --remote-debugging-port="$port" --remote-allow-origins=* \
    --user-agent="$ua" --accept-lang="$lang" \
    --window-size=1920,1080 --no-first-run --no-default-browser-check \
    about:blank >/dev/null 2>&1 9>&- &
  _cdp_port="$port"
  trap 'cdp_teardown; exit 130' INT TERM
  trap cdp_teardown EXIT

  for i in $(seq 1 60); do
    ws_url="$(python3 -c '
import json, sys, urllib.request
try:
    targets = json.load(urllib.request.urlopen("http://127.0.0.1:%s/json" % sys.argv[1], timeout=2))
    print(next((t["webSocketDebuggerUrl"] for t in targets if t.get("type") == "page"), ""))
except Exception:
    pass
' "$port" 2>/dev/null || true)"
    [[ -n "$ws_url" ]] && break
    sleep 0.25
  done
  if [[ -z "$ws_url" ]]; then
    echo "not-google-chrome: CDP endpoint on port $port never came up" >&2
    log_event err "cdp endpoint on port $port never came up: ${client_cmd[*]}"
    exit 78
  fi

  export CDP_WS_URL="$ws_url" CDP_PORT="$port"
  "$timeout_cmd" "$timeout" "${client_cmd[@]}" 9>&- || rc=$?
  if [[ $rc -eq 124 || $rc -eq 137 ]]; then
    log_event warning "cdp client timed out after ${timeout}s (exit $rc): ${client_cmd[*]}"
  fi
  exit "$rc"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t)                     timeout="$2"; shift 2 ;;
    --cdp)                  cdp=1; shift ;;
    --host)                 cdp_host="$2"; shift 2 ;;
    --pdf)                  mode_args=(--no-pdf-header-footer "--print-to-pdf=$2"); pdf=1; shift 2 ;;
    --yes-i-am-not-stupid)  override=1; shift ;;
    --)                     shift; break ;;
    *)                      break ;;
  esac
done

# Dump-dom self-exits fast; a CDP client runs a multi-step flow, so it gets a
# longer deadman by default.
if [[ -z "$timeout" ]]; then
  if [[ $cdp -eq 1 ]]; then timeout=90; else timeout=15; fi
fi

url=""
client_cmd=()
if [[ $cdp -eq 1 ]]; then
  client_cmd=("$@")
  if [[ ${#client_cmd[@]} -eq 0 ]]; then
    echo "Usage: not-google-chrome --cdp [-t SECONDS] [--host HOST] -- <client command ...>" >&2
    exit 64
  fi
else
  if [[ $# -lt 1 ]]; then
    echo "Usage: not-google-chrome [-t SECONDS] [--pdf PATH] [--yes-i-am-not-stupid] URL [extra-flag ...]" >&2
    echo "       not-google-chrome --cdp [-t SECONDS] [--host HOST] -- <client command ...>" >&2
    exit 64
  fi
  url="$1"; shift
  if [[ $override -eq 0 ]]; then
    for pat in "${ABUSE_PATTERNS[@]}"; do
      if [[ "$url" == *"$pat"* ]]; then
        cat >&2 <<EOF
not-google-chrome: refusing to fetch $url

This wrapper exists for sites that block automated access (Akamai,
Cloudflare, login walls). The URL matches abuse pattern '$pat', a site
that ordinarily responds to WebFetch or curl. Using a logged-in browser
session here is wasteful: it locks the user's user-data-dir, takes seconds
instead of milliseconds, and leaks attribution from their identity into a
fetch that did not need it.

Try WebFetch first; for raw bytes, try curl. If you genuinely need a
logged-in browser session against this URL (rare), re-run with
--yes-i-am-not-stupid.
EOF
        exit 77
      fi
    done
  fi
fi

case "$(uname)" in
  Linux)
    binary=chromium
    flock_cmd=flock
    timeout_cmd=timeout
    if [[ "$(readlink -f "$(command -v chromium 2>/dev/null || echo /missing)")" == /usr/bin/snap ]]; then
      user_data_dir="$HOME/snap/chromium/common/chromium"
    else
      user_data_dir="$HOME/.config/chromium"
    fi
    user_data_dir_args=(--user-data-dir="$user_data_dir")
    ;;
  Darwin)
    binary='/Applications/Chromium.app/Contents/MacOS/Chromium'
    timeout_cmd=gtimeout
    if   [[ -x /opt/homebrew/opt/util-linux/bin/flock ]]; then flock_cmd=/opt/homebrew/opt/util-linux/bin/flock
    elif [[ -x /usr/local/opt/util-linux/bin/flock   ]]; then flock_cmd=/usr/local/opt/util-linux/bin/flock
    else
      echo "not-google-chrome: flock not found; run 'brew install util-linux'" >&2
      exit 78
    fi
    user_data_dir="$HOME/Library/Application Support/Chromium"
    user_data_dir_args=(--user-data-dir="$user_data_dir")
    ;;
  *)
    echo "not-google-chrome: unsupported OS $(uname)" >&2
    exit 78
    ;;
esac

# UA (and, for --cdp, accept_lang) come from [browser] in config.ini so the
# headless fetch presents the same fingerprint as the browser the user logs in
# with. No default: a wrong UA silently diverging from the logged-in session is
# worse than a hard failure.
config="$HOME/.claude/skills/config.ini"
if [[ ! -f "$config" ]]; then
  echo "not-google-chrome: $config not found. Copy config.ini.example to config.ini and fill the [browser] section." >&2
  exit 78
fi
ua="$(config_get browser user_agent)"
if [[ -z "$ua" ]]; then
  cat >&2 <<EOF
not-google-chrome: [browser] user_agent missing from $config.

Set it to the exact User-Agent of the browser you log into sites with, so the
headless fetch matches your authenticated session. Capture it from a real
request in the DevTools Network panel. See config.ini.example.
EOF
  exit 78
fi
if [[ "$ua" == *HeadlessChrome* ]]; then
  echo "not-google-chrome: user_agent in $config contains 'HeadlessChrome', the marker sites block on. Use the UA of a real browser." >&2
  exit 78
fi

if [[ $cdp -eq 1 ]]; then
  lang="$(config_get browser accept_lang)"
  if [[ -z "$lang" ]]; then
    echo "not-google-chrome: [browser] accept_lang missing from $config (required for --cdp)." >&2
    exit 78
  fi
  run_cdp   # launches, runs the client, and exits via the teardown trap
fi

dumpdom_startup_guard   # refuse if the profile's startup would restore tabs and hang the render

common=(--headless=new "${mode_args[@]}" --window-size=3840,2160 --user-agent="$ua")

# Bounded lock: a stuck holder degrades to a fast, diagnosable error instead of
# an indefinite hang, while legitimate parallel fetches still serialise. The fd
# is held by this process (and inherited by the child) for the render's life.
exec 9>/tmp/chromium.lock
if ! "$flock_cmd" -w "$lock_wait" 9; then
  lock_diag
  log_event warning "lock-wait timeout after ${lock_wait}s: $url"
  exit 75
fi

# Run (not exec) so the outcome can be observed and logged: a render that times
# out or returns an empty body used to leave no trace, so a later session had to
# guess whether a site is flaky. Output is buffered to a temp file (tmpfs; a DOM
# dump is finite and emitted at once) then forwarded, which also avoids
# truncating the caller's stream.
tmpout="$(mktemp)"
rc=0
set +e
"$timeout_cmd" "$timeout" \
  "$binary" "${user_data_dir_args[@]}" "${common[@]}" "$@" "$url" > "$tmpout"
rc=$?
set -e
bytes="$(wc -c < "$tmpout" | tr -dc '0-9')"; [[ -n "$bytes" ]] || bytes=0
cat "$tmpout"
rm -f "$tmpout"
if [[ $rc -eq 124 || $rc -eq 137 ]]; then
  log_event warning "render timeout after ${timeout}s (exit $rc, $bytes bytes): $url"
elif [[ $pdf -eq 0 && "$bytes" == "0" ]]; then
  log_event warning "render returned empty (exit $rc): $url"
fi
exit "$rc"
