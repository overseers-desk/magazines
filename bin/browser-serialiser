#!/usr/bin/env tclsh
# browser-serialiser - run a browser skill inside a per-run policing harness.
#
# A browser skill is loaded into a SAFE interpreter that exposes only a policed
# command surface (nav/dump/eval/api/capture/.../emit). The skill never reaches a
# socket, file, exec, or raw CDP; the harness drives the real browser and enforces
# anti-ban web behaviour (pacing, view-before-fetch, 429/login backoff). See
# skills/serialised-browsing/COMMAND-SURFACE.md for the surface and the entry
# convention, and skills/lib/serialiser-harness.tcl for the policy.
#
# Usage:
#     browser-serialiser <skill-ref> [skill args...]
#
# <skill-ref> is a path relative to the toolbox skills/ directory, WITHOUT the
# .tcl suffix. "instagram.com/fetch-recent-posts" runs
# skills/instagram.com/fetch-recent-posts.tcl. The ref must stay inside skills/.
#
# Browser ownership (this phase: STANDALONE only):
#   The serialiser launches its own headless Chromium on the user's REAL logged-in
#   profile (flock /tmp/chromium.lock, --headless=new --remote-debugging-port on a
#   random port, --user-data-dir=<profile>), polls /json for the page-target ws
#   url, connects via cdp-client, runs the skill, and tears the browser down on
#   every exit. Launch/teardown mirrors the overseer's ov::launch_chromium /
#   ov::release (random port, ~40s cold-start poll budget for snap Chromium, kill
#   by launch PID AND by debug port plus a Singleton sweep so renderer children
#   never orphan and hold the profile).
#
#   OVERSEER-DELEGATION SEAM (Phase 3, not built here): when the overseer browser
#   broker answers on 127.0.0.1:11402, the serialiser will lease a browser by
#   reference and let the OVERSEER run the harness (central cross-job rate budget)
#   instead of launching Chromium. serialiser_delegate below is the stub Phase 3
#   fills; today it always declines, so the standalone path runs.
#
# Exit codes: 0 ok; 64 bad usage; 65 skill error; 66 terminal wall (rate-limited
#   / logged-out / checkpoint); 75 lock-wait timeout; 78 environment (no Chromium,
#   CDP endpoint never came up, config missing).

package require json
package require json::write

set ::ScriptDir [file dirname [file normalize [info script]]]
set ::Root [file dirname $::ScriptDir]   ;# toolbox root: holds bin/ and skills/

source [file join $::Root skills lib cdp-client.tcl]
source [file join $::Root skills lib serialiser-harness.tcl]

# ---------------------------------------------------------------------------
# Config: UA + accept-lang from the [browser] section of config.ini, so the
# headless fetch presents the logged-in browser's fingerprint.
# ---------------------------------------------------------------------------

proc config_path {} {
    return [file join $::env(HOME) .claude skills config.ini]
}

# Read one value from config.ini's [section] key. Empty if absent.
proc config_get {section key} {
    set path [config_path]
    if {![file exists $path]} { return "" }
    set f [open $path r]
    set data [read $f]
    close $f
    set cur ""
    foreach line [split $data \n] {
        set t [string trim $line]
        if {[regexp {^\[(.+)\]$} $t -> sect]} { set cur $sect; continue }
        if {$cur eq $section && [regexp "^\\s*$key\\s*=\\s*(.*)$" $line -> val]} {
            return [string trim $val]
        }
    }
    return ""
}

# ---------------------------------------------------------------------------
# Browser launch (standalone): pure-Tcl flock + launch + teardown.
# ---------------------------------------------------------------------------

# Locate the Chromium binary and the user-data-dir for the running OS. Returns a
# dict {binary <path> userDataDir <path>}; raises on an unsupported OS.
proc browser_locate {} {
    switch -- $::tcl_platform(os) {
        Linux {
            set binary [browser_which {chromium chromium-browser}]
            if {$binary eq ""} { error "no chromium binary on PATH" }
            # Snap and apt builds keep the profile in different places: a
            # snap-wrapped chromium uses the snap profile.
            if {[browser_is_snap $binary]} {
                set udd [file join $::env(HOME) snap chromium common chromium]
            } else {
                set udd [file join $::env(HOME) .config chromium]
            }
            return [dict create binary $binary userDataDir $udd]
        }
        Darwin {
            set binary /Applications/Chromium.app/Contents/MacOS/Chromium
            set udd [file join $::env(HOME) Library "Application Support" Chromium]
            return [dict create binary $binary userDataDir $udd]
        }
        default { error "unsupported OS $::tcl_platform(os)" }
    }
}

# First of $names found on PATH (absolute path), or "".
proc browser_which {names} {
    foreach n $names {
        foreach dir [split $::env(PATH) :] {
            set p [file join $dir $n]
            if {[file executable $p]} { return $p }
        }
    }
    return ""
}

# True if $binary resolves (through symlinks) to the snap launcher. The snap
# chromium is a symlink to /usr/bin/snap, so a launch uses the snap profile path.
proc browser_is_snap {binary} {
    set real $binary
    catch { set real [file normalize [file link $binary]] }
    # A snap shim is typically /snap/bin/chromium -> /usr/bin/snap, or the binary
    # path itself sits under /snap/.
    if {[string match "*/snap*" $binary] || [string match "*/snap*" $real]} { return 1 }
    catch {
        set real2 [exec readlink -f $binary]
        if {[string match "*/snap" $real2] || $real2 eq "/usr/bin/snap"} { return 1 }
    }
    return 0
}

# Acquire the single-browser lock so two serialiser instances never share the
# profile concurrently. The lock is the OS flock on /tmp/chromium.lock, plus an
# exclusive-create lock DIR fallback for hosts without flock; any other launcher
# that flocks the same file interlocks with us:
#   - flock on /tmp/chromium.lock is the shared OS lock. We hold it for our run
#     with a background `flock` holder whose stdout signals "acquired"; the holder
#     process is killed at teardown.
#   - On a host without flock, fall back to the exclusive-create dir lock with a
#     bounded wait and stale-PID sweep.
# Returns a token dict consumed by lock_release.
proc lock_acquire {waitSecs} {
    set lockPath /tmp/chromium.lock
    set flockBin [browser_which {flock}]
    if {$flockBin ne ""} {
        # A single background holder process queues on /tmp/chromium.lock (the
        # shared OS lock file, so any co-launcher that flocks it interlocks) with a
        # BLOCKING flock, so concurrent serialiser runs wait their turn in the
        # kernel's lock queue rather than racing a non-blocking poll (which under
        # load starved a waiter and timed it out instead of serialising it). The
        # holder is a shell that opens fd 9 on the lock file, blocks in `flock 9`
        # until granted, prints "acquired" to signal us, then EXECs sleep -- exec so
        # the shell is replaced, leaving exactly one process whose death (and fd-9
        # close) drops the lock at teardown. We read the channel for the "acquired"
        # line up to waitSecs; on timeout we kill the still-queued holder so it
        # leaves the queue cleanly (a blocking holder, unlike the old -n one, would
        # otherwise acquire later with nobody to use or release it). open's LIST
        # form execs without a shell re-split.
        set holderScript "exec 9>$lockPath; $flockBin 9; echo acquired; exec sleep 100000"
        set chan [open [list | sh -c $holderScript] r]
        set pids [pid $chan]
        fconfigure $chan -blocking 0
        set deadline [expr {[clock milliseconds] + $waitSecs * 1000}]
        while 1 {
            set line [gets $chan]
            if {![fblocked $chan] && $line eq "acquired"} {
                return [dict create kind flock chan $chan pids $pids]
            }
            if {[eof $chan]} {
                catch {close $chan}
                error "lock holder exited before acquiring $lockPath" {} {SERIALISER_LOCK 1}
            }
            if {[clock milliseconds] >= $deadline} {
                foreach p $pids { catch {exec kill -TERM $p} }
                catch {close $chan}
                error "lock-wait timeout after ${waitSecs}s on $lockPath" {} {SERIALISER_LOCK 1}
            }
            after 100
        }
    }
    # No flock: exclusive-create dir lock with bounded wait + stale sweep.
    set dir /tmp/chromium.serialiser.lock
    set deadline [expr {[clock milliseconds] + $waitSecs * 1000}]
    while 1 {
        if {![catch {file mkdir $dir; file attributes $dir} ] && [lock_dir_claim $dir]} {
            return [dict create kind dir dir $dir]
        }
        if {[clock milliseconds] >= $deadline} {
            error "lock-wait timeout after ${waitSecs}s on $dir" {} {SERIALISER_LOCK 1}
        }
        after 250
    }
}

# Try to claim the dir lock by writing our PID iff it is unclaimed or stale.
proc lock_dir_claim {dir} {
    set pidFile [file join $dir pid]
    if {[file exists $pidFile]} {
        set f [open $pidFile r]; set held [string trim [read $f]]; close $f
        if {[string is integer -strict $held] && [file exists /proc/$held]} {
            return 0   ;# a live holder
        }
    }
    set f [open $pidFile w]; puts -nonewline $f [pid]; close $f
    return 1
}

# Release the browser lock acquired by lock_acquire.
proc lock_release {token} {
    if {$token eq ""} return
    switch -- [dict get $token kind] {
        flock {
            # Kill the holder so the flock is dropped (sleep never writes again,
            # so closing the pipe alone would not signal it). SIGTERM the holder
            # pids, then close the pipe.
            foreach p [dict get $token pids] {
                catch {exec kill -TERM $p}
            }
            catch {close [dict get $token chan]}
        }
        dir { catch {file delete -force [dict get $token dir]} }
    }
}

# Launch headless Chromium on the real profile and return a dict {pid <p> wsurl
# <u>}. Mirrors the overseer's ov::launch_chromium: about:blank so a page target
# exists at once, UA/lang from config, the launch PID captured so teardown can
# kill it directly. Snap Chromium's cold start can take many seconds, so the
# /json poll allows up to ~40s. Raises if the endpoint never appears.
proc browser_launch {binary userDataDir ua lang port} {
    set cmd [list $binary \
        --user-data-dir=$userDataDir \
        --headless=new \
        --remote-debugging-port=$port --remote-allow-origins=* \
        --user-agent=$ua --accept-lang=$lang \
        --window-size=1920,1080 --no-first-run --no-default-browser-check \
        about:blank]
    set pid [exec {*}$cmd >/dev/null 2>@1 &]

    set wsUrl ""
    for {set i 0} {$i < 160} {incr i} {
        set wsUrl [browser_page_ws $port]
        if {$wsUrl ne ""} break
        after 250
    }
    if {$wsUrl eq ""} {
        # Kill by PID, then by the unique debug port as the belt for any child the
        # main process left behind, before raising.
        catch {exec kill -KILL $pid}
        catch {exec pkill -KILL -f "remote-debugging-port=$port"}
        error "CDP endpoint on port $port never came up" {} {SERIALISER_ENV 1}
    }
    return [dict create pid $pid wsurl $wsUrl]
}

# Read /json from the debug port and return the first page target's ws url, or
# "". Uses http::geturl (mirroring the overseer's ov::http_get_json): snap
# Chromium's CDP HTTP server returns no body to a hand-rolled HTTP/1.0 raw-socket
# GET, so the http package (which speaks the server's HTTP correctly) is the
# only reader that recovers the target list.
proc browser_page_ws {port} {
    package require http
    if {[catch {http::geturl "http://127.0.0.1:$port/json" -timeout 2000} tok]} {
        return ""
    }
    set code [http::ncode $tok]
    set data [http::data $tok]
    http::cleanup $tok
    if {$code != 200} { return "" }
    if {[catch {json::json2dict $data} targets]} { return "" }
    foreach t $targets {
        if {[dict exists $t type] && [dict get $t type] eq "page" \
                && [dict exists $t webSocketDebuggerUrl]} {
            return [dict get $t webSocketDebuggerUrl]
        }
    }
    return ""
}

# Tear down the browser, mirroring the overseer's ov::release: kill the launch
# PID AND pkill by the unique --remote-debugging-port (the belt for any renderer
# child the main process left behind, which carries --type=renderer not the port
# flag), SIGTERM to flush then SIGKILL to be sure, then sweep stale Singleton
# symlinks so the next launch is not blocked. Best-effort.
proc browser_teardown {pid port userDataDir} {
    catch {exec kill -TERM $pid}
    catch {exec pkill -TERM -f "remote-debugging-port=$port"}
    after 400
    catch {exec kill -KILL $pid}
    catch {exec pkill -KILL -f "remote-debugging-port=$port"}
    after 200
    if {$::tcl_platform(platform) eq "unix" && $::tcl_platform(os) eq "Linux"} {
        foreach s {SingletonLock SingletonCookie SingletonSocket} {
            set link [file join $userDataDir $s]
            if {[catch {file readlink $link} tgt]} continue
            set spid [lindex [split $tgt -] end]
            if {[string is integer -strict $spid] && ![file exists /proc/$spid]} {
                catch {file delete $link}
            }
        }
    }
}

# ---------------------------------------------------------------------------
# Direct render modes (--dump / --pdf). These run in THIS trusted interpreter,
# not a safe interp: they are the generic, non-policed counterpart to the policed
# skill-by-reference mode, the one-shot DOM dump and PDF render of a single URL.
# They reuse the same flock + launch + teardown, drive the browser directly over
# cdp-client (no skill, no policing surface), and so may write files (--pdf).
# Browser config (UA/lang) is read the same way the skill path reads it, so the
# render presents the logged-in fingerprint.
# ---------------------------------------------------------------------------

# Resolve UA/lang from config (shared by both render modes). Dies on a missing
# or HeadlessChrome UA, matching the skill path.
proc render_browser_config {} {
    set ua [config_get browser user_agent]
    if {$ua eq ""} {
        die 78 "[config_path]: [browser] user_agent missing (copy config.ini.example and fill it)"
    }
    if {[string match "*HeadlessChrome*" $ua]} {
        die 78 "user_agent contains 'HeadlessChrome', the marker sites block on; use a real browser's UA"
    }
    set lang [config_get browser accept_lang]
    if {$lang eq ""} { set lang "en-US,en;q=0.9" }
    return [dict create ua $ua lang $lang]
}

# Navigate the connected CDP client to $url and wait for the page to finish
# loading, up to $timeoutSecs. Page.enable is issued so Page.loadEventFired
# arrives; drainEvents parks events while we watch for it. If the load event
# never comes within budget we proceed anyway (a slow site may still have a
# usable DOM): a deadman timeout, then emit whatever rendered.
proc render_navigate {cdp url timeoutSecs} {
    $cdp cdp Page.enable
    $cdp cdp Page.navigate [dict create url $url]
    set deadline [expr {[clock milliseconds] + $timeoutSecs * 1000}]
    while {[clock milliseconds] < $deadline} {
        set remain [expr {$deadline - [clock milliseconds]}]
        $cdp drainEvents [expr {($remain < 500 ? $remain : 500) / 1000.0}]
        foreach ev [$cdp events] {
            if {[dict exists $ev method] \
                    && [dict get $ev method] eq "Page.loadEventFired"} {
                $cdp clearEvents
                return
            }
        }
        $cdp clearEvents
    }
}

# --dump: launch, navigate, print the rendered DOM to stdout, tear down. Reuses
# the standalone lock/launch/teardown. Default timeout 15s.
proc run_dump {url timeoutSecs} {
    set cfg [render_browser_config]
    return [render_session $timeoutSecs $cfg [list apply {{url timeoutSecs cdp} {
        render_navigate $cdp $url $timeoutSecs
        set html [$cdp evaluate {document.documentElement.outerHTML}]
        puts $html
    }} $url $timeoutSecs]]
}

# --pdf: launch, navigate, Page.printToPDF, decode the base64 and write it to
# $outfile (this interpreter is trusted, so the harness writes the file). Reuses
# the standalone lock/launch/teardown. Default timeout 30s.
proc run_pdf {outfile url timeoutSecs} {
    set cfg [render_browser_config]
    return [render_session $timeoutSecs $cfg [list apply {{url timeoutSecs outfile cdp} {
        render_navigate $cdp $url $timeoutSecs
        set resp [$cdp cdp Page.printToPDF [dict create \
            printBackground true preferCSSPageSize true]]
        if {![dict exists $resp result data]} {
            error "Page.printToPDF returned no data" {} {SERIALISER_ENV 1}
        }
        set bytes [base64::decode [dict get $resp result data]]
        set f [open $outfile wb]
        puts -nonewline $f $bytes
        close $f
    }} $url $timeoutSecs $outfile]]
}

# Shared body for the render modes: take the lock, launch Chromium on the real
# profile, connect CDP, run $body (a command prefix invoked with the cdp client
# appended), and tear the browser down on every exit path. Returns a process
# exit code. Mirrors run_standalone's lock/launch/teardown and error mapping;
# the only difference is it drives the browser directly instead of through the
# safe-interp harness.
proc render_session {timeoutSecs cfg body} {
    set ua [dict get $cfg ua]
    set lang [dict get $cfg lang]

    set loc [browser_locate]
    set binary [dict get $loc binary]
    set udd [dict get $loc userDataDir]

    set port [expr {10000 + int(rand()*40000)}]
    set lockToken ""
    set launched 0
    set launchPid ""
    set rc 0
    if {[catch {
        set lockToken [lock_acquire 600]
        set br [browser_launch $binary $udd $ua $lang $port]
        set launchPid [dict get $br pid]
        set wsUrl [dict get $br wsurl]
        set launched 1
        set cdp [cdp::connect $wsUrl]
        try {
            {*}$body $cdp
        } finally {
            catch {$cdp close}
        }
    } err errOpts]} {
        set code [dict get $errOpts -errorcode]
        if {[lindex $code 0] eq "SERIALISER_LOCK"} {
            puts stderr "browser-serialiser: $err"
            set rc 75
        } elseif {[lindex $code 0] eq "SERIALISER_ENV"} {
            puts stderr "browser-serialiser: $err"
            set rc 78
        } else {
            puts stderr "browser-serialiser: $err"
            set rc 65
        }
    }
    if {$launched} { browser_teardown $launchPid $port $udd }
    lock_release $lockToken
    return $rc
}

# ---------------------------------------------------------------------------
# Overseer-delegation seam (Phase 3). When the overseer browser broker answers on
# 127.0.0.1:11402, let IT run the harness (central cross-job rate budget, one shared
# browser pool) instead of launching our own Chromium; fall through to the
# standalone launch when the overseer is absent.
# ---------------------------------------------------------------------------

# The overseer control port, BI_OVERSEER_PORT or the 11402 default (mirrors the
# overseer's cfg::port), so a test overseer on another port is reachable too.
proc overseer_port {} {
    if {[info exists ::env(BI_OVERSEER_PORT)] && $::env(BI_OVERSEER_PORT) ne ""} {
        return $::env(BI_OVERSEER_PORT)
    }
    return 11402
}

# True if the overseer answers GET /health on the loopback control port.
proc overseer_up {} {
    package require http
    set port [overseer_port]
    if {[catch {http::geturl "http://127.0.0.1:$port/health" -timeout 1500} tok]} {
        return 0
    }
    set code [http::ncode $tok]
    http::cleanup $tok
    return [expr {$code == 200}]
}

# Reset the silence-watchdog: a fresh frame proves the overseer is alive and working
# its queue, so we restart the bail timer. It fires only after a stretch of total
# silence (no progress frame, no heartbeat, no terminal), which is the one thing we
# read as a hang. While frames flow we wait unbounded - a long queue or a long run is
# not a failure, it is the overseer doing its job and telling us so.
proc overseer_wd_reset {} {
    catch {after cancel $::ovsd(wd)}
    set ::ovsd(wd) [after 90000 {set ::ovsd(done) timeout}]
}

# Drive one readable event on the streamed /run socket: accumulate bytes, split into
# newline-framed lines, and hand each to overseer_stream_line. On EOF, flush any
# trailing unterminated line first (so an old single-reply overseer, or a terminal
# frame that arrived without its newline, is still parsed) before declaring the stream
# closed. Mirrors the reader in the overseer's desktop/lib/sse.tcl.
proc overseer_stream_read {} {
    if {[catch {read $::ovsd(sock)} chunk]} { set ::ovsd(done) error; return }
    if {$chunk eq "" && [eof $::ovsd(sock)]} {
        if {$::ovsd(buf) ne ""} { overseer_stream_line [string trimright $::ovsd(buf) "\r\n"]; set ::ovsd(buf) "" }
        if {$::ovsd(done) eq ""} { set ::ovsd(done) closed }
        return
    }
    append ::ovsd(buf) $chunk
    while {[set nl [string first "\n" $::ovsd(buf)]] >= 0} {
        set line [string trimright [string range $::ovsd(buf) 0 $nl] "\r\n"]
        set ::ovsd(buf) [string range $::ovsd(buf) [expr {$nl + 1}] end]
        overseer_stream_line $line
        if {$::ovsd(done) ne ""} return
    }
}

# One line of the streamed response. Skip the HTTP status line and headers until the
# blank line; after that each non-blank line is one ndjson frame. A frame tagged
# "type" is a progress or heartbeat keepalive - reset the watchdog and keep waiting.
# An untagged frame is the terminal {result,fault} envelope; capture it and stop.
proc overseer_stream_line {line} {
    if {!$::ovsd(inbody)} {
        if {[string match "HTTP/*" $line]} {
            set code [lindex [split $line " "] 1]
            if {$code ne "200"} { set ::ovsd(code) $code; set ::ovsd(done) http }
        } elseif {$line eq ""} {
            set ::ovsd(inbody) 1
        }
        return
    }
    if {$line eq ""} return
    overseer_wd_reset
    if {[catch {json::json2dict $line} obj]} { return }
    if {[dict exists $obj type]} { return }
    set ::ovsd(env) $obj
    set ::ovsd(done) terminal
}

# Try to run the skill via the overseer broker. Returns {delegated 1 result <emit>}
# on success, {delegated 0} to fall through to standalone when the overseer is
# absent. When the overseer IS up it owns the outcome: a skill fault from /run is
# returned as a delegated error (we do NOT silently re-launch our own Chromium and
# contend with the overseer for the shared profile). POST /run carries the skill ref,
# its args as a JSON array string, and our pid as the clientId - the rotation key the
# overseer fairly queues us by, and its presence is what opts us into the streamed
# reply: progress/heartbeat frames while we queue and run, then the terminal
# {result:<emit>} or {fault:{shape,detail}} frame. We wait as long as frames arrive and
# bail only on ~90s of silence.
proc serialiser_delegate {skillRef skillArgs} {
    if {![overseer_up]} { return [dict create delegated 0] }
    set port [overseer_port]
    set argsJson [args_to_json $skillArgs]
    set body "{\"skillRef\":[json::write string $skillRef],\"argsJson\":[json::write string $argsJson],\"clientId\":[json::write string [pid]]}"
    set bodyBytes [encoding convertto utf-8 $body]
    if {[catch {socket 127.0.0.1 $port} sock]} { die 65 "overseer /run connect failed: $sock" }
    array unset ::ovsd
    array set ::ovsd {buf "" inbody 0 done "" env "" code "" wd ""}
    set ::ovsd(sock) $sock
    fconfigure $sock -blocking 0 -buffering none -translation binary
    set req "POST /run HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Type: application/json\r\n"
    append req "Content-Length: [string length $bodyBytes]\r\nConnection: close\r\n\r\n"
    if {[catch { puts -nonewline $sock $req$bodyBytes; flush $sock }]} { catch {close $sock}; die 65 "overseer /run write failed" }
    overseer_wd_reset
    fileevent $sock readable overseer_stream_read
    vwait ::ovsd(done)
    catch {after cancel $::ovsd(wd)}
    catch {fileevent $sock readable {}}
    catch {close $sock}
    switch -- $::ovsd(done) {
        timeout { die 65 "overseer /run: no frame for 90s, treating as hung" }
        http    { die 65 "overseer /run HTTP $::ovsd(code)" }
        closed  { die 65 "overseer /run closed before a result" }
        error   { die 65 "overseer /run read error" }
    }
    set resp $::ovsd(env)
    if {[dict exists $resp fault] && [dict get $resp fault] ne "null" && [dict get $resp fault] ne ""} {
        set f [dict get $resp fault]
        set shape [expr {[dict exists $f shape] ? [dict get $f shape] : "skill"}]
        set detail [expr {[dict exists $f detail] ? [dict get $f detail] : ""}]
        if {$shape eq "terminal"} { die 66 "terminal $detail" }
        die 65 "overseer skill fault: $detail"
    }
    set result [expr {[dict exists $resp result] ? [dict get $resp result] : ""}]
    return [dict create delegated 1 result $result]
}

# Encode a Tcl list of skill args as a JSON array string (each element a JSON
# string), matching what /run expects to json2dict back into a list.
proc args_to_json {skillArgs} {
    set parts {}
    foreach a $skillArgs { lappend parts [json::write string $a] }
    return "\[[join $parts ,]\]"
}

# ---------------------------------------------------------------------------
# Standalone run: own the browser, run the skill under the harness.
# ---------------------------------------------------------------------------

proc run_standalone {skillRef skillArgs} {
    serialiser::setRoot $::Root
    set skillPath [serialiser::resolveSkill $skillRef]

    set ua [config_get browser user_agent]
    if {$ua eq ""} {
        die 78 "[config_path]: [browser] user_agent missing (copy config.ini.example and fill it)"
    }
    if {[string match "*HeadlessChrome*" $ua]} {
        die 78 "user_agent contains 'HeadlessChrome', the marker sites block on; use a real browser's UA"
    }
    set lang [config_get browser accept_lang]
    if {$lang eq ""} { set lang "en-US,en;q=0.9" }

    set loc [browser_locate]
    set binary [dict get $loc binary]
    set udd [dict get $loc userDataDir]

    # Random debug port (mirrors the overseer's ov::launch_chromium) so a leftover
    # process from a failed run on one port never blocks the next launch.
    set port [expr {10000 + int(rand()*40000)}]
    set lockToken ""
    set launched 0
    set launchPid ""
    set rc 0
    set out ""
    if {[catch {
        set lockToken [lock_acquire 600]
        set br [browser_launch $binary $udd $ua $lang $port]
        set launchPid [dict get $br pid]
        set wsUrl [dict get $br wsurl]
        set launched 1
        set cdp [cdp::connect $wsUrl]
        try {
            set out [serialiser::run $skillPath $cdp $skillArgs]
        } finally {
            catch {$cdp close}
        }
    } err errOpts]} {
        set code [dict get $errOpts -errorcode]
        if {[lindex $code 0] eq "SERIALISER_TERMINAL"} {
            puts stderr "browser-serialiser: terminal [lindex $code 1]"
            set rc 66
        } elseif {[lindex $code 0] eq "SERIALISER_LOCK"} {
            puts stderr "browser-serialiser: $err"
            set rc 75
        } elseif {[lindex $code 0] eq "SERIALISER_ENV"} {
            puts stderr "browser-serialiser: $err"
            set rc 78
        } else {
            puts stderr "browser-serialiser: $err"
            set rc 65
        }
    }
    if {$launched} { browser_teardown $launchPid $port $udd }
    lock_release $lockToken
    if {$rc == 0} { puts $out }
    return $rc
}

proc die {code msg} {
    puts stderr "browser-serialiser: $msg"
    exit $code
}

# ---------------------------------------------------------------------------
# Entry.
# ---------------------------------------------------------------------------

# Parse a leading `-t SECS` from a flag list, returning {secs <n|""> rest <list>}.
proc render_parse_timeout {args} {
    set secs ""
    set rest {}
    for {set i 0} {$i < [llength $args]} {incr i} {
        set a [lindex $args $i]
        if {$a eq "-t"} {
            incr i
            set secs [lindex $args $i]
            if {![string is integer -strict $secs]} {
                die 64 "-t needs an integer seconds value"
            }
        } else {
            lappend rest $a
        }
    }
    return [dict create secs $secs rest $rest]
}

proc usage {} {
    puts stderr "Usage:"
    puts stderr "  browser-serialiser <skill-ref> \[skill args...\]"
    puts stderr "      run a policed browser skill (e.g. instagram.com/fetch-recent-posts posts <handle>)"
    puts stderr "  browser-serialiser --dump \[-t SECS\] <url>"
    puts stderr "      render <url> and print its DOM to stdout (default -t 15)"
    puts stderr "  browser-serialiser --pdf \[-t SECS\] <outfile> <url>"
    puts stderr "      render <url> and write a PDF to <outfile> (default -t 30)"
    exit 64
}

proc main {} {
    fconfigure stdout -encoding utf-8
    fconfigure stderr -encoding utf-8
    global argv
    if {[llength $argv] < 1} { usage }

    # Direct render modes (--dump / --pdf): no skill, no policing surface; run in
    # this trusted interpreter. They share the standalone lock/launch/teardown.
    switch -- [lindex $argv 0] {
        --dump {
            set p [render_parse_timeout {*}[lrange $argv 1 end]]
            set rest [dict get $p rest]
            if {[llength $rest] != 1} { usage }
            set secs [dict get $p secs]
            if {$secs eq ""} { set secs 15 }
            exit [run_dump [lindex $rest 0] $secs]
        }
        --pdf {
            set p [render_parse_timeout {*}[lrange $argv 1 end]]
            set rest [dict get $p rest]
            if {[llength $rest] != 2} { usage }
            set secs [dict get $p secs]
            if {$secs eq ""} { set secs 30 }
            exit [run_pdf [lindex $rest 0] [lindex $rest 1] $secs]
        }
    }

    set skillRef [lindex $argv 0]
    set skillArgs [lrange $argv 1 end]

    # Phase 3 seam: try the overseer first, fall through to standalone.
    set d [serialiser_delegate $skillRef $skillArgs]
    if {[dict get $d delegated]} {
        puts [dict get $d result]
        exit 0
    }
    exit [run_standalone $skillRef $skillArgs]
}

main
