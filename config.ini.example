# Copy this file to ${XDG_CONFIG_HOME:-$HOME/.config}/magazines/config.ini and fill in your values.
# Each site skill lists the keys it needs under Prerequisites in its SKILL.md.

[browser]
# Match the UA and locale list of the browser you log into sites with, so that
# headless/CDP runs present the same fingerprint as your authenticated session.
# Capture from a real request in DevTools Network panel (any site).
user_agent = Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36
accept_lang = es-ES,es,en

[serpapi]
api_key = <API-KEY>

[brave.com]
# Brave Search API subscription token, read by bin/brave-search.
# Get one at https://api-dashboard.search.brave.com/ (a free tier exists).
api_key = <API-KEY>

[supplier.getyourguide.com]
supplier_id = <ID>

[interlinetravel.com.au]
email = <EMAIL>
password = <PASSWORD>

[otter.ai]
# Off unless set. On true, `capture` pushes each meeting it commits to the
# business repo's remote, rather than leaving the commit local.
auto_push = false

[qantas.com]
member_id = <ID>
last_name = <SURNAME>
pin = <PIN>
